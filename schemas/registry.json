{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mcp-poste:registry:v2",
  "title": "MCP-Poste Schema Registry",
  "description": "Central registry of all schemas - Single Source of Truth - v2 with 2-stage pipeline",
  "version": "2.0.0",
  "schemas": {
    "meta": {
      "id": "urn:mcp-poste:meta:meta-schema:v1",
      "path": "meta/meta-schema.json",
      "version": "1.0.0",
      "description": "Mandatory metadata block for all objects"
    },
    "input": {
      "id": "urn:mcp-poste:input:schema:v1",
      "path": "input/schema.json",
      "version": "1.0.0",
      "description": "PDF input document structure"
    },
    "extraction": {
      "id": "urn:mcp-poste:extraction:schema:v1",
      "path": "extraction/schema.json",
      "version": "1.0.0",
      "description": "Raw text extraction from PDFs"
    },
    "job": {
      "id": "urn:mcp-poste:job:schema:v1",
      "path": "job/schema.json",
      "version": "1.0.0",
      "description": "Structured job offer model"
    },
    "candidate": {
      "id": "urn:mcp-poste:candidate:schema:v1",
      "path": "candidate/schema.json",
      "version": "1.0.0",
      "description": "Structured candidate model"
    },
    "search": {
      "id": "urn:mcp-poste:search:schema:v1",
      "path": "search/schema.json",
      "version": "1.0.0",
      "description": "Search operations and results"
    },
    "resource": {
      "id": "urn:mcp-poste:resource:schema:v1",
      "path": "resource/schema.json",
      "version": "1.0.0",
      "description": "Discovered resources linked to CV/job"
    },
    "mcp_config": {
      "id": "urn:mcp-poste:mcp_config:schema:v1",
      "path": "mcp_config/schema.json",
      "version": "1.0.0",
      "description": "Dynamic MCP configuration"
    },
    "claude_api": {
      "id": "urn:mcp-poste:claude_api:schema:v1",
      "path": "claude_api/schema.json",
      "version": "1.0.0",
      "description": "Claude API interaction tracking"
    },
    "web": {
      "id": "urn:mcp-poste:web:schema:v1",
      "path": "web/schema.json",
      "version": "1.0.0",
      "description": "Web-sourced data (pages, search, APIs)"
    },
    "grand_meta": {
      "id": "urn:mcp-poste:grand_meta:schema:v1",
      "path": "grand_meta/schema.json",
      "version": "1.0.0",
      "description": "Grand meta-schema — unified 7-category analysis output"
    },
    "analysis": {
      "id": "urn:mcp-poste:analysis:schema:v1",
      "path": "analysis/schema.json",
      "version": "1.0.0",
      "description": "Candidate-job analysis and comparison"
    },
    "generation": {
      "id": "urn:mcp-poste:generation:schema:v1",
      "path": "generation/schema.json",
      "version": "1.0.0",
      "description": "Generated output artifacts"
    },
    "pipeline": {
      "id": "urn:mcp-poste:pipeline:schema:v1",
      "path": "pipeline/schema.json",
      "version": "1.0.0",
      "description": "Pipeline execution plan and state"
    }
  },
  "pipeline_flow": {
    "stage_1_discovery": [
      { "step": "1.0", "name": "init", "description": "Load schemas, init session" },
      { "step": "1.1", "name": "ingest", "description": "Extract text from offer + CV PDFs", "output_schema": "extraction" },
      { "step": "1.2", "name": "structure", "description": "Claude structures job + candidate models", "output_schema": ["job", "candidate"] },
      { "step": "1.3", "name": "mcp_select", "description": "Claude selects useful MCPs based on content", "output_schema": "mcp_config" },
      { "step": "1.4", "name": "mcp_test", "description": "Test selected MCPs, keep working ones", "output_schema": "mcp_config" },
      { "step": "1.5", "name": "resource_discover", "description": "Use MCPs to find resources about company, skills, market", "output_schema": ["search", "resource"] },
      { "step": "1.6", "name": "resource_register", "description": "Register discovered resources in our MCP", "output_schema": "resource" }
    ],
    "stage_2_analysis": [
      { "step": "2.1", "name": "resource_consult", "description": "Fetch and parse all discovered resources", "output_schema": ["web", "resource"] },
      { "step": "2.2", "name": "analysis_mcp_select", "description": "Claude selects MCPs for deep analysis", "output_schema": "mcp_config" },
      { "step": "2.3", "name": "analysis_mcp_test", "description": "Test analysis MCPs", "output_schema": "mcp_config" },
      { "step": "2.4", "name": "analysis_execute", "description": "Run analysis queries via MCPs + Claude", "output_schema": "analysis" },
      { "step": "2.5", "name": "combine", "description": "Combine all results into meta-analysis", "output_schema": "analysis" },
      { "step": "2.6", "name": "generate", "description": "Generate final report and artifacts", "output_schema": "generation" }
    ]
  },
  "capability_mapping": {
    "ingestion": ["1.1"],
    "structuration": ["1.2"],
    "mcp_discovery": ["1.3", "1.4", "2.2", "2.3"],
    "enrichissement": ["1.5", "1.6", "2.1"],
    "raisonnement": ["1.3", "2.2", "2.4", "2.5"],
    "validation": ["1.4", "2.3"],
    "nlp": ["2.1"],
    "generation": ["2.6"]
  }
}
